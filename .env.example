# ============================================
# Gemini AI API Key
# ============================================
# Google AI Studio (https://ai.google.dev/) で取得してください
# ダッシュボード > Get API key からキーを作成できます
VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Supabase 設定
# ============================================
# Supabase Dashboard (https://supabase.com/dashboard) で取得
# Project Settings > API から確認できます
# ※ URLは https://your-project-id.supabase.co の形式です
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# サービスロールキー（管理者操作のみ使用、絶対に公開しないこと）
# ※ このキーはサーバーサイドでのみ使用してください
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# Stripe 決済設定
# ============================================
# Stripe Dashboard (https://dashboard.stripe.com/apikeys) で取得
# テストモード: pk_test_xxx と sk_test_xxx
# 本番モード: pk_live_xxx と sk_live_xxx （本番環境のみ）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ============================================
# アプリケーション設定
# ============================================
NODE_ENV=development

# オプション：カスタム設定
# VITE_APP_NAME=CC-SaaS
# VITE_API_BASE_URL=http://localhost:3000

# ============================================
# 認証設定
# ============================================
# アプリアクセス用の共通パスワード
# ※ 強力なパスワードを設定してください（本番環境では特に重要）
# 例: my-secure-password-2024!
VITE_APP_PASSWORD=your-secure-password-here
